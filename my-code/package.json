{
  "name": "my-code",
  "version": "0.3.0-dev",
  "description": "Terminal coding agent powered by Ollama — reference-architecture CLI on Bun",
  "type": "module",
  "bin": {
    "my-code": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target node --external react --external ink --external react-devtools-core --external has-flag --external @modelcontextprotocol/sdk",
    "build:tsc": "tsc -p tsconfig.build.json",
    "dev": "bun run src/cli.ts",
    "start": "bun run dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/lodash-es": "^4.17.12",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "has-flag": "4",
    "imapflow": "^1.3.3",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.3.6",
    "marked": "^14.1.3",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/diff": "^5.2.0",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  }
}
